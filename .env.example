# Mobile app environment variables.
# Copy to `.env` (or `.env.local`) and fill in. All EXPO_PUBLIC_* vars are
# inlined into the client bundle at build time — never put secrets here.

# Backend API base URL, including the version prefix.
EXPO_PUBLIC_API_BASE_URL=https://your-backend.example.com/v1

# Clerk publishable key (Clerk dashboard → API keys).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# PostHog (product analytics). These names match what
# `eas integrations:posthog:connect` writes, so the EAS integration and a local
# .env are interchangeable. Run `npx eas-cli@latest integrations:posthog:connect
# --region US --no-session-replay` to manage them via EAS instead.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxx
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
